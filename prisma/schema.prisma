generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Filament {
  id            String     @id @default(uuid())
  material      String
  brand         String
  colorName     String
  colorHex      String
  currentWeight Float
  totalWeight   Float
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  printJobs     PrintJob[]
}

model PrintJob {
  id          String   @id @default(uuid())
  partName    String
  weightGrams Float
  timeHours   Float
  status      Status   @default(QUEUED)
  filamentId  String
  filament    Filament @relation(fields: [filamentId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Status {
  COMPLETED
  PRINTING
  QUEUED
}